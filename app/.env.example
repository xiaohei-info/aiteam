# AI Team app local runtime configuration template
#
# Usage:
#   cp .env.example .env
#   # then edit .env for your machine
#
# Loaded automatically by:
#   - ./start.sh
#   - ./ctl.sh start|restart
#   - python bootstrap.py
#
# Keep real local secrets only in .env. This template is safe to commit.
#
# Scope note:
# - This file is for app/ (host + WebUI + AI Team additions) runtime variables.
# - Hermes provider API keys usually still live in HERMES_HOME/.env unless you
#   explicitly choose to duplicate or override them here.

# ------------------------------------------------------------
# Core local development defaults
# ------------------------------------------------------------
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=8787
HERMES_WEBUI_PYTHON=/absolute/path/to/aiteam/app/.venv/bin/python
HERMES_WEBUI_AGENT_DIR=/absolute/path/to/hermes-agent
DATABASE_URL=postgresql://aiteam:change-me@127.0.0.1:5433/aiteam_test
TEST_DATABASE_URL=postgresql://aiteam:change-me@127.0.0.1:5433/aiteam_test
HERMES_WEBUI_STATE_DIR=/absolute/path/to/aiteam/app/.state
HERMES_WEBUI_DEFAULT_WORKSPACE=/absolute/path/to/aiteam/app/workspace

# ------------------------------------------------------------
# Hermes home / config location
# ------------------------------------------------------------
# By default app/ will use ~/.hermes. Uncomment to isolate this project.
# HERMES_HOME=/absolute/path/to/aiteam/app/.hermes
# HERMES_CONFIG_PATH=/absolute/path/to/aiteam/app/.hermes/config.yaml

# ------------------------------------------------------------
# Web server / network
# ------------------------------------------------------------
# TLS (when terminating HTTPS directly in app/)
# HERMES_WEBUI_TLS_CERT=/absolute/path/to/fullchain.pem
# HERMES_WEBUI_TLS_KEY=/absolute/path/to/privkey.pem

# Extra CSP connect-src entries, comma-separated or space-separated depending on your usage
# HERMES_WEBUI_CSP_CONNECT_EXTRA=wss://example.com,https://example.com

# Test-only network block switch used by server.py; keep disabled for normal runs
# HERMES_WEBUI_TEST_NETWORK_BLOCK=0

# Slow request logging threshold in seconds
# HERMES_WEBUI_SLOW_REQUEST_SECONDS=15

# ------------------------------------------------------------
# Auth / onboarding
# ------------------------------------------------------------
# Enable password protection for the Web UI
# HERMES_WEBUI_PASSWORD=change-me
# HERMES_WEBUI_SESSION_TTL=1209600

# Optional WebAuthn/passkey related switches
# HERMES_WEBUI_PASSKEY=1

# Skip or loosen onboarding gates only when the environment is already prepared
# HERMES_WEBUI_SKIP_ONBOARDING=1
# HERMES_WEBUI_ONBOARDING_OPEN=1

# ------------------------------------------------------------
# Runtime / bootstrap behavior
# ------------------------------------------------------------
# Force foreground mode when invoking bootstrap.py directly
# HERMES_WEBUI_FOREGROUND=1

# Preserve shell-provided env vars instead of letting app/.env overwrite them
# Mostly internal; ctl.sh already preserves explicit shell overrides.
# HERMES_WEBUI_PRESERVE_ENV=1

# ------------------------------------------------------------
# UI / product behavior
# ------------------------------------------------------------
# Override default model shown in the WebUI picker
# HERMES_WEBUI_DEFAULT_MODEL=gpt-5.4

# Allow zipped-folder download limits
# HERMES_WEBUI_FOLDER_ZIP_MAX_MB=1024
# HERMES_WEBUI_FOLDER_ZIP_MAX_FILES=50000

# External notes / knowledge integrations
# HERMES_WEBUI_EXTERNAL_NOTES_SOURCES=/path/one:/path/two
# WIKI_PATH=/absolute/path/to/wiki
# JOPLIN_URL=http://127.0.0.1:41184
# JOPLIN_TOKEN=change-me

# Prefill message injection hooks
# HERMES_WEBUI_PREFILL_MESSAGES_SCRIPT=/absolute/path/to/prefill.py
# HERMES_WEBUI_PREFILL_MESSAGES_SCRIPT_TIMEOUT=10
# HERMES_PREFILL_MESSAGES_FILE=/absolute/path/to/prefill-messages.json

# Media access roots beyond the default workspace/state locations
# MEDIA_ALLOWED_ROOTS=/srv/shared/media:/mnt/assets

# ------------------------------------------------------------
# Hermes runtime / model env fallbacks
# ------------------------------------------------------------
# These are only needed if you intentionally want app/ to override Hermes-side defaults.
# HERMES_MODEL=gpt-5.4
# OPENAI_MODEL=gpt-5.4
# LLM_MODEL=gpt-5.4
# CODEX_HOME=/home/ubuntu/.codex

# Extra internal debug switch used by some routes
# HERMES_DEBUG_SLOW=1

# ------------------------------------------------------------
# ctl.sh local process bookkeeping
# ------------------------------------------------------------
# HERMES_WEBUI_PID_FILE=/absolute/path/to/aiteam/app/.state/aiteam.pid
# HERMES_WEBUI_LOG_FILE=/absolute/path/to/aiteam/app/logs/aiteam.log
# HERMES_WEBUI_CTL_STATE_FILE=/absolute/path/to/aiteam/app/.state/aiteam.ctl.env

# ------------------------------------------------------------
# Gateway / health probe overrides
# ------------------------------------------------------------
# GATEWAY_HEALTH_URL=http://127.0.0.1:8642
# HERMES_GATEWAY_HEALTH_URL=http://127.0.0.1:8642

# ------------------------------------------------------------
# WSL autostart helper (scripts/wsl/hermes_webui_autostart.sh)
# ------------------------------------------------------------
# HERMES_WEBUI_REPO=/absolute/path/to/aiteam/app
# HERMES_WEBUI_LOG_DIR=/home/ubuntu/.hermes/webui/logs
# HERMES_WEBUI_HEALTH_HOST=127.0.0.1
# HERMES_WEBUI_HEALTH_URL=http://127.0.0.1:8787/health
# HERMES_WEBUI_LOCK_FILE=/tmp/hermes-webui-autostart.lock
# HERMES_WEBUI_REQUIRE_AGENT_PROCESS=0
# HERMES_WEBUI_STARTUP_GRACE_SECONDS=2

# ------------------------------------------------------------
# Docker / container-related variables from the original Hermes WebUI project
# ------------------------------------------------------------
# These are mainly for docker-compose / container startup, not local ./ctl.sh runs.
# UID=1000
# GID=1000
# HERMES_WORKSPACE=/home/ubuntu/workspace
# WANTED_UID=1000
# WANTED_GID=1000
# HERMES_UID=1000
# HERMES_GID=1000
# HERMES_SKIP_CHMOD=1
# HERMES_HOME_MODE=0640
# UV_CACHE_DIR=/uv_cache
# ENV_IGNORELIST=
# ENV_OBFUSCATE_PART=
